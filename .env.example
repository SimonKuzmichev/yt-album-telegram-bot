BOT_TOKEN=...
# Optional admin override for commands/daily job while allowlist-based scheduling is pending
ALLOWED_CHAT_ID=123456789

YTM_AUTH_PATH=secrets/browser.json
CACHE_PATH=data/albums_cache.json
HISTORY_PATH=data/sent_history.json
LIBRARY_LIMIT=500
LOG_LEVEL=INFO
ENVIRONMENT=dev
USE_DB_SCHEDULER=true

DATABASE_URL=postgresql://app:app@localhost:5432/ytabot

# Worker loop tuning
WORKER_ID=worker-1
WORKER_POLL_SECONDS=10
WORKER_CLAIM_BATCH_SIZE=10
WORKER_RETRY_BACKOFF_BASE_SECONDS=30
WORKER_RETRY_BACKOFF_MAX_SECONDS=1800
WORKER_DUE_WINDOW_SECONDS=60
WORKER_JOB_LEASE_SECONDS=300

# Fallback app timezone for status formatting when the admin override user
# does not exist in DB yet.
DEFAULT_TIMEZONE=UTC
