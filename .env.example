BOT_TOKEN=...
# Optional admin override for commands/daily job while allowlist-based scheduling is pending
ALLOWED_CHAT_ID=123456789

LIBRARY_LIMIT=500
LOG_LEVEL=INFO
ENVIRONMENT=dev
USE_DB_SCHEDULER=true

DATABASE_URL=postgresql://app:app@localhost:5432/ytabot
REDIS_URL=redis://localhost:6379/0
# Optional container-only overrides for Compose deployments.
CONTAINER_DATABASE_URL=postgresql://app:app@db:5432/ytabot
CONTAINER_REDIS_URL=redis://redis:6379/0
CONTAINER_PROXY_URL=socks5h://host.docker.internal:2080
CONTAINER_NO_PROXY=127.0.0.1,localhost,db,redis,prometheus,grafana,bot-app,worker,caddy
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
CADDY_SITE_ADDRESS=albums.example.com
SPOTIFY_CLIENT_ID=...
SPOTIFY_CLIENT_SECRET=...
SPOTIFY_REDIRECT_URI=https://albums.example.com/oauth/spotify/callback
SPOTIFY_OAUTH_STATE_TTL_SECONDS=600
SPOTIFY_TOKEN_REFRESH_WINDOW_SECONDS=600
NOW_RATE_LIMIT_HOURLY=6
NOW_RATE_LIMIT_DAILY=20
NEXTCYCLE_RATE_LIMIT_HOURLY=6
NEXTCYCLE_RATE_LIMIT_DAILY=20
REFRESH_RATE_LIMIT_HOURLY=2
REFRESH_RATE_LIMIT_DAILY=6
# Test-only database for integration tests.
TEST_DATABASE_URL=postgresql://app:app@localhost:5432/ytabot_test

# Worker loop tuning
WORKER_ID=worker-1
WORKER_POLL_SECONDS=10
WORKER_CLAIM_BATCH_SIZE=10
WORKER_RETRY_BACKOFF_BASE_SECONDS=30
WORKER_RETRY_BACKOFF_MAX_SECONDS=1800
WORKER_DUE_WINDOW_SECONDS=60
WORKER_JOB_LEASE_SECONDS=300
PROVIDER_SYNC_INTERVAL_SECONDS=21600
PROMETHEUS_METRICS_PORT=8000
WORKER_PROMETHEUS_METRICS_PORT=8001

# Fallback app timezone for status formatting when the admin override user
# does not exist in DB yet.
DEFAULT_TIMEZONE=UTC

CREDENTIALS_MASTER_KEY=...
